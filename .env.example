# Used only to sign the httpOnly app session cookie.
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
BOOTSTRAP_ADMIN_SECRET=
FORCE_BOOTSTRAP_ADMIN=false
CUSTOMER_EMAIL=
CUSTOMER_PASSWORD=
CUSTOMER_NAME=
CUSTOMER_COMPANY_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional future AI integrations. Do not expose these to the browser.
OPENAI_API_KEY=
OPENAI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
GROQ_FALLBACK_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GOOGLE_MAPS_API_KEY=
GOOGLE_API_KEY=

# Optional report email delivery through Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
REPORT_FROM_EMAIL=

# Optional future backend integrations.
DATABASE_URL=
NEXT_PUBLIC_SITE_URL=https://www.hkdijital.com.tr

# Runtime / platform flags.
NODE_ENV=
VERCEL=
CRON_SECRET=

# Meta / Facebook integrations. Keep non-public values server-side only.
NEXT_PUBLIC_META_PIXEL_ID=
META_DATASET_ID=
META_ACCESS_TOKEN=
META_AD_LIBRARY_ACCESS_TOKEN=
META_BUSINESS_ID=
META_APP_ID=
META_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INTEGRATION_TOKEN_SECRET=
INTEGRATION_ENCRYPTION_KEY=

# Google Ads / GA4 integrations. Keep private key escaped with \n in Vercel.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
